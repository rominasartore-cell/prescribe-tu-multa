# Production Environment Variables
# Copia este archivo a .env.production y completa con tus valores reales
# NO incluyas este archivo en git con valores sensibles

# ========== CONFIGURACIÓN DEL SITIO ==========
NEXT_PUBLIC_SITE_URL=https://prescribetumulta.cl

# ========== SUPABASE (Storage + Database) ==========
# El proyecto debe ser: ezdcwbxyqsbdlyvroixw
SUPABASE_URL=https://ezdcwbxyqsbdlyvroixw.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://ezdcwbxyqsbdlyvroixw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ========== BASE DE DATOS (PostgreSQL via Supabase) ==========
DATABASE_URL=postgresql://user:password@host/dbname?schema=public
DIRECT_URL=postgresql://user:password@host/dbname?schema=public

# ========== AUTENTICACIÓN (NextAuth) ==========
NEXTAUTH_URL=https://prescribetumulta.cl
NEXTAUTH_SECRET=ED5+AQEQGi0Rl9zDxcnIkIbw/3bAvjAib8c3b3ba+qo=

# ========== EMAIL (Resend) ==========
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== IA (Anthropic Claude) ==========
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ========== PAGOS (Mercado Pago) - OPCIONAL ==========
